# Copy this file to .env.langfuse and replace placeholder secrets.

# Core app secrets (required)
LANGFUSE_SALT=replace-with-random-string
LANGFUSE_ENCRYPTION_KEY=replace-with-64-hex-chars
LANGFUSE_NEXTAUTH_SECRET=replace-with-random-string

# Optional infra credentials
LANGFUSE_POSTGRES_USER=postgres
LANGFUSE_POSTGRES_PASSWORD=postgres
LANGFUSE_POSTGRES_DB=postgres
LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse
LANGFUSE_REDIS_AUTH=langfuse-redis-secret
LANGFUSE_MINIO_ROOT_USER=minio
LANGFUSE_MINIO_ROOT_PASSWORD=miniosecret

# Ports (optional overrides)
LANGFUSE_WEB_PORT=3003
LANGFUSE_WORKER_PORT=3030
LANGFUSE_POSTGRES_PORT=5433
LANGFUSE_CLICKHOUSE_HTTP_PORT=8123
LANGFUSE_CLICKHOUSE_TCP_PORT=9000
LANGFUSE_MINIO_API_PORT=9090
LANGFUSE_MINIO_CONSOLE_PORT=9091
LANGFUSE_REDIS_PORT=6380

# Bootstrap defaults (optional)
LANGFUSE_INIT_ORG_ID=refined-chatbot-org
LANGFUSE_INIT_ORG_NAME=Refined Chatbot
LANGFUSE_INIT_PROJECT_ID=refined-chatbot
LANGFUSE_INIT_PROJECT_NAME=Refined Chatbot
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-refined-chatbot-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-refined-chatbot-local
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_PASSWORD=Admin123!
LANGFUSE_INIT_USER_NAME=Admin
